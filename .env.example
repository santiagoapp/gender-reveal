# Copia este archivo a .env.local para desarrollo local.
# En producción, configura estos valores como Secrets/Variables en GitHub.

# ── Lectura del Sheet (solo en build, NO se exponen al navegador) ──
SHEET_ID=tu_spreadsheet_id
GOOGLE_API_KEY=tu_api_key_de_google_sheets
SHEET_TAB=Participación

# ── Escritura (Apps Script Web App) — SÍ se exponen al navegador ──
NEXT_PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXX/exec
NEXT_PUBLIC_CONFIRM_TOKEN=CAMBIA_ESTE_TOKEN

# ── Ruta base (solo necesaria para GitHub Pages project site) ──
# Para desarrollo local déjalo vacío.
# BASE_PATH=/gender-reveal
# NEXT_PUBLIC_BASE_PATH=/gender-reveal
